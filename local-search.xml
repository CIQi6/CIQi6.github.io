enter">2</td><td align="center">5</td><td align="center">Z</td></tr><tr><td align="center">H</td><td align="center">H</td><td align="center">T</td><td align="center">T</td><td align="center">6</td><td align="center"></td></tr><tr><td align="center">I</td><td align="center">I</td><td align="center">U</td><td align="center">U</td><td align="center">7</td><td align="center"></td></tr><tr><td align="center">J</td><td align="center">L</td><td align="center">V</td><td align="center">V</td><td align="center">8</td><td align="center">8</td></tr><tr><td align="center">K</td><td align="center"></td><td align="center">W</td><td align="center">W</td><td align="center">9</td><td align="center"></td></tr><tr><td align="center">L</td><td align="center">J</td><td align="center">X</td><td align="center">X</td><td align="center"></td><td align="center"></td></tr><tr><td align="center">我们只要把上面的表格按顺序用数组制成表格，如数组索引0代表字符A的镜像。。。</td><td align="center"></td><td align="center"></td><td align="center"></td><td align="center"></td><td align="center"></td></tr><tr><td align="center">我们根据字符的运算很容易就能算出相应的索引了。但我们制作的表格大写字母和数字是连续的</td><td align="center"></td><td align="center"></td><td align="center"></td><td align="center"></td><td align="center"></td></tr><tr><td align="center">而ASCALL码里却是不连续的，所以我们在计算字母的镜像索引和计算数字的镜像索引要分开计算。</td><td align="center"></td><td align="center"></td><td align="center"></td><td align="center"></td><td align="center"></td></tr></tbody></table></li></ul><h3 id="代码实现"><a href="#代码实现" class="headerlink" title="代码实现"></a>代码实现</h3><figure class="highlight c"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br><span class="line">30</span><br><span class="line">31</span><br></pre></td><td class="code"><pre><code class="hljs C">&#123;<br><span class="hljs-meta">#<span class="hljs-keyword">include</span><span class="hljs-string">&lt;stdio.h&gt;</span></span><br><span class="hljs-meta">#<span class="hljs-keyword">include</span><span class="hljs-string">&lt;string.h&gt;</span></span><br><span class="hljs-meta">#<span class="hljs-keyword">include</span><span class="hljs-string">&lt;ctype.h&gt;</span></span><br><span class="hljs-type">const</span> <span class="hljs-type">char</span>* rev =<span class="hljs-string">&quot;A   3  HIL JM O   2TUVWXY51SE Z  8 &quot;</span> <span class="hljs-comment">//制作镜像表</span><br><span class="hljs-type">const</span> <span class="hljs-type">char</span>* msg[] = &#123;<span class="hljs-string">&quot;not a palindrome&quot;</span>,<span class="hljs-string">&quot;a regular palindrome&quot;</span>,<span class="hljs-string">&quot;a mirrored string&quot;</span>,<span class="hljs-string">&quot;a mirrored palindrome&quot;</span>&#125;<span class="hljs-comment">//四种组合，目的是为了减少消耗，简便化，下面会进一步说明。</span><br><br><span class="hljs-comment">//镜像串的判断函数</span><br><span class="hljs-type">char</span> r(<span class="hljs-type">char</span> ch)&#123;<br><span class="hljs-keyword">if</span>(<span class="hljs-built_in">isalpha</span>(ch)) <span class="hljs-keyword">return</span> rev[ch-<span class="hljs-string">&#x27;A&#x27;</span>];<span class="hljs-comment">//isalpha函数是用来判断是否为字母，声明包含在ctype.h头文件</span><br><span class="hljs-keyword">return</span> rev[ch-<span class="hljs-string">&#x27;0&#x27;</span>+<span class="hljs-number">25</span>];<br>&#125;<br><br><span class="hljs-type">int</span> <span class="hljs-title function_">main</span><span class="hljs-params">()</span>&#123;<br><span class="hljs-type">char</span> s[<span class="hljs-number">30</span>];<br><span class="hljs-keyword">while</span>(<span class="hljs-built_in">scanf</span>(%s,s)==<span class="hljs-number">1</span>)&#123;<br><span class="hljs-type">int</span> len = <span class="hljs-built_in">strlen</span>(s);<br><span class="hljs-type">int</span> p = <span class="hljs-number">1</span>,m=<span class="hljs-number">1</span>;<span class="hljs-comment">//用于回文串和镜像串状态判断，p有1，0态，代表是否回文串；m有1，0态，代表是否镜像串.</span><br><span class="hljs-keyword">for</span>(<span class="hljs-type">int</span> i;i&lt;(len+<span class="hljs-number">1</span>)/<span class="hljs-number">2</span>;i++)&#123;<br><span class="hljs-keyword">if</span>(s[i]!=s[len<span class="hljs-number">-1</span>-i]) p=<span class="hljs-number">0</span>; <span class="hljs-comment">//不是回文串</span><br><span class="hljs-keyword">if</span>(r(s[i])!=s[len<span class="hljs-number">-1</span>-i]) m=<span class="hljs-number">0</span>;<span class="hljs-comment">//不是镜像串</span><br>&#125;<br><span class="hljs-built_in">printf</span>(<span class="hljs-string">&quot;%s -- is %ss.\n\n&quot;</span>,s,msg[m*<span class="hljs-number">2</span>+p]);<br><span class="hljs-comment">//msg[]就是用于这里的效率</span><br><span class="hljs-comment">//msg有四种状态，不是回文串非镜像，是回文串非镜像，是镜像串非回文，是镜像回文串。</span><br><span class="hljs-comment">//为什么回文状态p*1，而镜像状态m**2？</span><br><span class="hljs-comment">//分析msg[0],msg[1],区别是否回文，下标差为1；msg[2],msg[3]区别为是否回文，下标差为1.而msg[0]和msg[2]区别为是否镜像，下标差为2，msg[1]和msg[3]区别是是否镜像,下标差为2。可以简单理解为权重。我们也可以修改msg状态顺序来让实现msg[p*2+m]，只要改成msg[] = &#123;&quot;not a mirrored string&quot;,&quot;a mirrored sring&quot;,&quot; a palindrome&quot;,&quot;a mirrored palindrome&quot;&#125;</span><br>&#125;<br>&#125;<br><br>&#125;<br></code></pre></td></tr></table></figure>]]></content>
    
    
    
